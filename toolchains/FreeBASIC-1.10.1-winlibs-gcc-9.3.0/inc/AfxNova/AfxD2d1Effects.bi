' // Function pointer that sets a property on an effect.
'typedef HRESULT (CALLBACK *PD2D1_PROPERTY_SET_FUNCTION)(
'    _In_ IUnknown *effect,
'    _In_reads_(dataSize) const BYTE *data,
'    UINT32 dataSize
'    );
