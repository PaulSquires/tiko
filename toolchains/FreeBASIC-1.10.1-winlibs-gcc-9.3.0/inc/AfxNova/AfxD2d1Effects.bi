' // Function pointer that gets a property from an effect.
'typedef HRESULT (CALLBACK *PD2D1_PROPERTY_GET_FUNCTION)(
'    _In_ const IUnknown *effect,
'    _Out_writes_opt_(dataSize) BYTE *data,
'    UINT32 dataSize,
'    _Out_opt_ UINT32 *actualSize
'    );
type PD2D1_PROPERTY_GET_FUNCTION AS FUNCTION (BYVAL effect AS const IUnknown PTR, BYVAL pData AS BYTE PTR, _
   BYVAL dataSize AS UINT32, BYVAL actualSize AS UINT32 PTR) AS HRESULT

